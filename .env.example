# ============================================================
# langchain-stack environment variables
# Copy to .env and fill in actual values
# ============================================================

# --- LiteLLM Proxy ---
LITELLM_PROXY_URL=http://<your-litellm-host>:4000/v1
LITELLM_API_KEY=sk-change-me

# --- LangChain API ---
LANGCHAIN_API_PORT=8100

# --- ChromaDB ---
CHROMA_PORT=8200

# --- Judge settings ---
MAX_JUDGE_RETRIES=2

# --- RAGAS settings (Phase 3B+) ---
RAGAS_RESPONSE_RELEVANCY_THRESHOLD=0.7

# --- Ingestion settings (Phase 4A+) ---
EMBEDDING_MODEL_NAME=cl-nagoya/ruri-v3-310m
INGEST_CHUNK_SIZE=1000
INGEST_CHUNK_OVERLAP=200
CHROMA_ADMIN_PORT=3001
