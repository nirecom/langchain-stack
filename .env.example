# ============================================================
# langchain-stack environment variables
# Copy to .env and fill in actual values
# ============================================================

# --- LiteLLM Proxy ---
LITELLM_PROXY_URL=http://<your-litellm-host>:4000/v1
LITELLM_API_KEY=sk-change-me

# --- LangChain API ---
LANGCHAIN_API_PORT=8100

# --- ChromaDB ---
CHROMA_PORT=8200

# --- Judge settings ---
MAX_JUDGE_RETRIES=2

# --- RAGAS settings (Phase 3B+) ---
RAGAS_RESPONSE_RELEVANCY_THRESHOLD=0.7

# --- Direct Endpoint Fallback (bypasses LiteLLM) ---
LLAMA_SERVER_URL=https://<local-gpu-host>:8443/v1
PORTABLE_LLM_SERVER_URL=https://<mac-host>:8443/v1
CLOUD_API_URL=https://api.openai.com/v1
CLOUD_API_KEY=sk-your-cloud-key
REASONER_LOCAL_MODEL=openai/Qwen3.5-27B-IQ3_M
REASONER_PORTABLE_MODEL=openai/Qwen3-14B-Q4_K_M
REASONER_CLOUD_MODEL=openai/gpt-4o
JUDGE_LOCAL_MODEL=openai/Qwen2.5-7B-Instruct-Q4_K_M
JUDGE_PORTABLE_MODEL=openai/Qwen2.5-7B-Instruct-Q4_K_M
JUDGE_CLOUD_MODEL=openai/gpt-4o-mini
HEALTH_PROBE_TIMEOUT=2.0

# --- Ingestion settings (Phase 4A+) ---
EMBEDDING_MODEL_NAME=cl-nagoya/ruri-v3-310m
INGEST_CHUNK_SIZE=1000
INGEST_CHUNK_OVERLAP=200
CHROMA_ADMIN_PORT=3001

# --- Access control & audit (Phase 4B+) ---
INGEST_API_KEY=change-me-ingest
CHAT_API_KEY=change-me-chat
AUDIT_LOG_PATH=/data/audit/ingest.jsonl
