# ============================================================
# langchain-stack environment variables
# Copy to .env and fill in actual values
# ============================================================

# --- LiteLLM Proxy ---
LITELLM_PROXY_URL=http://<your-litellm-host>:4000/v1
LITELLM_API_KEY=sk-change-me

# --- LangChain API ---
LANGCHAIN_API_PORT=8100

# --- ChromaDB ---
CHROMA_PORT=8200

# --- Judge settings ---
MAX_JUDGE_RETRIES=2

# --- RAGAS settings (Phase 3B+) ---
RAGAS_RESPONSE_RELEVANCY_THRESHOLD=0.7
RAGAS_FAITHFULNESS_THRESHOLD=0.7
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.7

# --- Direct Endpoint Fallback (bypasses LiteLLM) ---
LLAMA_SERVER_URL=https://<local-gpu-host>:8443/v1
PORTABLE_LLM_SERVER_URL=https://<mac-host>:8443/v1
CLOUD_API_URL=https://api.openai.com/v1
CLOUD_API_KEY=sk-your-cloud-key
REASONER_LOCAL_MODEL=openai/Qwen3.5-27B-IQ3_M
REASONER_PORTABLE_MODEL=openai/Qwen3-14B-Q4_K_M
REASONER_CLOUD_MODEL=openai/gpt-4o
JUDGE_LOCAL_MODEL=openai/Qwen2.5-7B-Instruct-Q4_K_M
JUDGE_PORTABLE_MODEL=openai/Qwen2.5-7B-Instruct-Q4_K_M
JUDGE_CLOUD_MODEL=openai/gpt-4o-mini
HEALTH_PROBE_TIMEOUT=2.0

# --- Ingestion settings (Phase 4A+) ---
# Selected via A/B eval (Phase 4D): bgem3 EN 0.691 / JA 0.798 (top scorer)
# Other candidates: cl-nagoya/ruri-v3-310m | Qwen/Qwen3-Embedding-0.6B | jinaai/jina-embeddings-v3
EMBEDDING_MODEL_NAME=BAAI/bge-m3
# cpu | cuda  (cuda: batch ingest on GPU; query always uses cpu)
INGEST_DEVICE=cpu
INGEST_CHUNK_SIZE=1000
INGEST_CHUNK_OVERLAP=200
RAG_TOP_K=10
CHROMA_ADMIN_PORT=3001

# --- Access control & audit (Phase 4B+) ---
INGEST_API_KEY=change-me-ingest
CHAT_API_KEY_KYOKO=change-me-kyoko
CHAT_API_KEY_NIRE=change-me-nire
CHAT_API_KEY_EDGE=change-me-edge
CHAT_API_KEY_LUTE=change-me-lute
AUDIT_LOG_PATH=/data/audit/ingest.jsonl
# --- Config file paths (Docker defaults shown; override for standalone host execution) ---
# When running evaluation scripts directly on the host (outside Docker), set these to
# absolute paths pointing to the config/ directory in the repo root.
MODELS_CONFIG_PATH=/config/models.yaml
JUDGE_RULES_PATH=/config/judge_rules.yaml
ACCESS_CONTROL_PATH=/config/access_control.yaml

# --- OpenSearch (Phase 4F+) ---
OPENSEARCH_PORT=9200
# Docker-internal URL (used by langchain-api container via docker-compose).
# When running evaluation scripts directly on the host, override to the host-accessible URL:
#   OPENSEARCH_URL=http://127.0.0.1:9200
OPENSEARCH_URL=http://opensearch:9200
OSD_PORT=5601
OS_INDEX_PREFIX=ls_
# opensearch | chroma (移行期間中: chroma で即時ロールバック可)
VECTOR_BACKEND=opensearch
HYBRID_PIPELINE_NAME=hybrid-bm25-knn
# dense | header+dense | hybrid | hybrid+header
SEARCH_MODE=hybrid+header

# --- Langfuse v3 (Phase 5+) ---
# Python SDK credentials — issued in Langfuse UI after project creation
# (distinct from the server-internal keys below)
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me
# Docker-internal service name — do NOT use 127.0.0.1 here; that resolves to the
# container itself, not the host. Use http://127.0.0.1:13000 only in host-side scripts
# (evaluation, curl) that run outside Docker. Set empty to disable tracing.
LANGFUSE_HOST=http://langfuse-web:3000
# true = startup fails if Langfuse is unreachable; false = warn and continue
LANGFUSE_REQUIRED=true

LANGFUSE_WEB_PORT=13000
# Public URL the browser uses to reach Langfuse. NextAuth uses this for callbacks,
# cookie domain, and CSRF origin checks — must match what users actually type.
# Local-only: http://127.0.0.1:13000 / Cloudflare-tunneled: https://langfuse.<your-domain>
LANGFUSE_NEXTAUTH_URL=https://langfuse.example.com

# Server secrets — generate each with:
#   Linux/Mac : openssl rand -hex 32
#   pwsh      : -join ((1..32)|%{'{0:x2}' -f (Get-Random -Max 256)})
# ENCRYPTION_KEY must be exactly 64 hex chars (= 32-byte output)
LANGFUSE_NEXTAUTH_SECRET=change-me-nextauth-secret
LANGFUSE_SALT=change-me-salt
LANGFUSE_ENCRYPTION_KEY=change-me-64-hex-chars

# DB / infra passwords — generate each with:
#   Linux/Mac : openssl rand -hex 24
#   pwsh      : -join ((1..24)|%{'{0:x2}' -f (Get-Random -Max 256)})
# hex only — base64 breaks DATABASE_URL parsing
LANGFUSE_POSTGRES_PASSWORD=change-me-postgres-pw
LANGFUSE_CLICKHOUSE_PASSWORD=change-me-clickhouse-pw
LANGFUSE_MINIO_ROOT_PASSWORD=change-me-minio-pw
LANGFUSE_REDIS_AUTH=change-me-redis-auth
# MinIO placeholder — replace with actual AWS region (e.g. ap-northeast-1) when migrating to S3
LANGFUSE_S3_EVENT_UPLOAD_REGION=change-me-s3-region
